local function startTornado()
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    
    local player = Players.LocalPlayer
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    
    task.wait(2)
    
    local tools = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Tool") or obj:IsA("Model") and (obj.Name:lower():find("tool") or obj.Name:lower():find("weapon") or obj.Name:lower():find("sword") or obj.Name:lower():find("gun")) then
            table.insert(tools, obj)
        elseif obj:IsA("BasePart") and (obj.Name:lower():find("tool") or obj.Name:lower():find("weapon") or obj.Name:lower():find("sword") or obj.Name:lower():find("gun") or obj.Name:lower():find("item")) then
            table.insert(tools, obj)
        end
    end
    
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character then
            for _, obj in pairs(otherPlayer.Character:GetDescendants()) do
                if obj:IsA("Tool") then
                    table.insert(tools, obj)
                end
            end
            if otherPlayer:FindFirstChild("Backpack") then
                for _, tool in pairs(otherPlayer.Backpack:GetDescendants()) do
                    if tool:IsA("Tool") then
                        table.insert(tools, tool)
                    end
                end
            end
        end
    end
    
    for _, tool in pairs(tools) do
        if tool:IsA("BasePart") then
            tool.CanCollide = false
            tool.Anchored = false
            tool.Massless = true
        elseif tool:IsA("Model") and tool.PrimaryPart then
            tool.PrimaryPart.CanCollide = false
            tool.PrimaryPart.Anchored = false
            tool.PrimaryPart.Massless = true
            for _, part in pairs(tool:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                    part.Massless = true
                end
            end
        elseif tool:IsA("Tool") and tool:FindFirstChild("Handle") then
            tool.Handle.CanCollide = false
            tool.Handle.Anchored = false
            tool.Handle.Massless = true
            for _, part in pairs(tool:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                    part.Massless = true
                end
            end
        end
    end
    
    if #tools == 0 then return end
    
    local angle = 0
    local height = 0
    
    tornadoConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if not player.Character or not hrp or not hrp.Parent then
            stopTornado()
            return
        end
        
        angle = angle + (deltaTime * tornadoSpeed)
        height = height + deltaTime
        
        for i, tool in pairs(tools) do
            if not tool or not tool.Parent then continue end
            
            local toolHeight = ((i * 2) + (math.sin(height + i) * 3)) % 50
            local toolRadius = 8 + (toolHeight * 0.3)
            local toolAngle = angle + ((i * 0.5) % (math.pi * 2))
            
            local offset = Vector3.new(
                math.cos(toolAngle) * toolRadius,
                toolHeight,
                math.sin(toolAngle) * toolRadius
            )
            
            local rotation = CFrame.Angles(
                height * 2 + i,
                toolAngle + math.pi / 2,
                height + i
            )
            
            if tool:IsA("BasePart") then
                tool.CFrame = hrp.CFrame * CFrame.new(offset) * rotation
                tool.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                tool.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            elseif tool:IsA("Model") and tool.PrimaryPart then
                tool:SetPrimaryPartCFrame(hrp.CFrame * CFrame.new(offset) * rotation)
                tool.PrimaryPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                tool.PrimaryPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            elseif tool:IsA("Tool") and tool:FindFirstChild("Handle") then
                tool.Handle.CFrame = hrp.CFrame * CFrame.new(offset) * rotation
                tool.Handle.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                tool.Handle.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            end
        end
    end)
end


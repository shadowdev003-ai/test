               TweenService:Create(hrp, TweenInfo.new(0.2, Enum.EasingStyle.Linear), {CFrame = thrp.CFrame}):Play()
           end
           
           local function watch(plr)
               if plr == LocalPlayer then return end
               task.spawn(function()

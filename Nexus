                freeCamConnection = game:GetService("RunService").RenderStepped:Connect(function()
                    local moveVec = Vector3.new(0, 0, 0)
                    if keys[Enum.KeyCode.W] then moveVec = moveVec + camera.CFrame.LookVector end
                    if keys[Enum.KeyCode.S] then moveVec = moveVec - camera.CFrame.LookVector end
                    if keys[Enum.KeyCode.A] then moveVec = moveVec - camera.CFrame.RightVector end
                    if keys[Enum.KeyCode.D] then moveVec = moveVec + camera.CFrame.RightVector end
                    if keys[Enum.KeyCode.E] then moveVec = moveVec + Vector3.new(0, 1, 0) end
                    if keys[Enum.KeyCode.Q] then moveVec = moveVec - Vector3.new(0, 1, 0) end
                    
                    camera.CFrame = camera.CFrame + moveVec * speed
                end)
                
                game:GetService("UserInputService").InputBegan:Connect(function(input)
                    keys[input.KeyCode] = true
                end)
                
                game:GetService("UserInputService").InputEnded:Connect(function(input)

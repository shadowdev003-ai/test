local startTime = tick()

task.spawn(function()
  while true do
    task.wait(1)
    local elapsed = tick() - startTime
    local hours = math.floor(elapsed / 3600)
    local minutes = math.floor((elapsed % 3600) / 60)
    local seconds = math.floor(elapsed % 60)
    local timeString = string.format("%02d:%02d:%02d", hours, minutes, seconds)
    if scriptTimeLabel and scriptTimeLabel.SetText then
      scriptTimeLabel:SetText(timeString)
    end
  end
end)

task.spawn(function()
  while true do
    task.wait(0.1)
    local ping = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()
    local pingText = math.floor(ping) .. " ms"
    if pingLabel and pingLabel.SetText then
      pingLabel:SetText(pingText)
    end
  end
end)

task.spawn(function()
  local RunService = game:GetService("RunService")
  local frameCount = 0
  local lastUpdate = tick()
  
  RunService.Heartbeat:Connect(function()
    frameCount = frameCount + 1
    local now = tick()
    if now - lastUpdate >= 1 then
      if fpsLabel and fpsLabel.SetText then
        fpsLabel:SetText(tostring(frameCount) .. " FPS")
      end
      frameCount = 0
      lastUpdate = now
    end
  end)
end)

